{
  "name": "notification-service",
  "version": "1.0.0",
  "description": "Serviço de notificações do BurgerApp",
  "main": "src/infra/server.js",
  "scripts": {
    "start": "node src/infra/server.js",
    "dev": "nodemon src/infra/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:bdd": "cucumber-js tests/bdd/features --require tests/bdd/steps"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/unit/**/*.test.js"]
  }
}
